# Rendered Quarto output (served by GitHub Pages)
docs/

# R session / workspace files
.Rhistory
.RData
.Rproj.user/
*.Rproj.user
.Renviron
.Rapp.history
*-Ex.R

# Environment variables (DB credentials)
.env

# OS files
.DS_Store
Thumbs.db

# Data folders (generated by the pipeline or too large for Git)
# Keep the directories but ignore their contents
data-raw/*
!data-raw/.gitkeep
data-processed/*
!data-processed/.gitkeep
tablas-finales/*
!tablas-finales/.gitkeep
descargas/*
!descargas/.gitkeep
